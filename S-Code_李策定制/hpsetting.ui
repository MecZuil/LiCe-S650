       <string notr="true">QDoubleSpinBox
{
background-color:transparent;

background-image:url(:/res/res/spinbox_text_bg.png);
color:#7CA6C9;
border:0px;
}
QDoubleSpinBox::up-button {
	subcontrol-origin:border;
    subcontrol-position:right;
    image: url(:/res/res/right_arrow_n.png);
    width: 40;
    height: 40;       
}
QDoubleSpinBox::down-button {
subcontrol-origin:border;
    subcontrol-position:left;
    border-image: url(:/res/res/left_arrow_n.png);
    width: 40;
    height: 40;
}
/*按钮按下样式*/
QDoubleSpinBox::up-button:pressed{
	subcontrol-origin:border;
    subcontrol-position:right;
    image: url(:/res/res/right_arrow_s.png);
    width: 40;
    height: 40;       
}
  
QDoubleSpinBox::down-button:pressed{
    subcontrol-position:left;
    image: url(:/res/res/left_arrow_s.png);
    width: 40;
    height: 40;
}

QDoubleSpinBox::down-arrow:disabled,QSpinBox::down-arrow:off 
{ 
   border-image: url(:/res/res/left_arrow_d.png);
    width: 40;
    height: 40;
}

QDoubleSpinBox::up-arrow:disabled,QSpinBox::up-arrow:off 
{ 
   border-image: url(:/res/res/right_arrow_d.png);
    width: 40;
    height: 40;
}
</string>
