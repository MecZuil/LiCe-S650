      <property name="styleSheet">
       <string notr="true">QListWidget
{
	border: 1px solid #7CA6C9;
	color:#7CA6C9;
	
	background-image: url(:/res/res/setting_background.png);
}

QScrollBar:vertical {
	border:0px solid #7CA6C9;
	background-color:#32CC99;
	width:25px;
	margin:25 0 25 0px;
}

/* 滑块设置 */
QScrollBar::handle:vertical {
/*	background-color:#7CA6C9;*/	
	background-color: rgb(83, 166, 249);
	border:1px solid #7CA6C9;
	height:30px;
	max-height:20px;
}

/* 底部控制块 */
QScrollBar::add-line:vertical {
	border:0px solid #7CA6C9;
	background-color:transparent;
	width:25px;
	height:25px;
	subcontrol-position:bottom;
	subcontrol-origin:margin;
	border-image: url(:/res/res/m_down_arrow_s.png);
	
}

/* 顶部控制块 */
QScrollBar::sub-line:vertical {
	border:0px solid #7CA6C9;
	background-color:transparent;
	width:25px;
	height:25px;
	subcontrol-position:top;
	subcontrol-origin:margin;
	border-image: url(:/res/res/m_up_arrow_s.png);
	
}

/* 控制块上的小箭头 */
QScrollBar::up-arrow:vertical,QScrollBar::down-arrow:vertical {
	border:0px;
	width:25px;
	height:25px;
}

/* 滑块上边区域 */
QScrollBar::add-page:vertical {
	background-color:transparent;
}

/* 滑块下边区域 */
QScrollBar::sub-page:vertical {
	background-color:transparent;
}
</string>
