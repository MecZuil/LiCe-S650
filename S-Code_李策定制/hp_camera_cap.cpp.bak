Hp_Camera_Cap::Hp_Camera_Cap(QWidget *parent) :
    QWidget(parent),
    ui(new Ui::Hp_Camera_Cap)
{
    ui->setupUi(this);
    setWindowFlags(Qt::FramelessWindowHint | Qt::Dialog);
    setWindowModality(Qt::WindowModal);
    m_isPms = false;
    isS3X0 = false;
    voiceflag = false;
    m_isKjg = false;
    m_isZoomSave = false;
    textflag = false;
    isContinuedFreeze = false;
    cap_state = true;
    isSuperImage = false;
    saveflag = false;
    sr_baocunflag = false;
    sr_canceflag = false;
    autoUpdateIsChecked = false;
    autoUpdateWhoEmit = false;
    IsInAotuUpdate = false;//不处于自动上传模式
    IsClickCancelUpload = false;
    autoUpdateonce = false;
    isErrPmsPhoto = false;
    fidpid = false;
    isSisFlag = false;
    isSisOK = false;
    isGuoWangFlag = false;
    dateFolderPath = "/run/media/mmcblk2p1/DCIM/";
    SlotCheckAndCreateDateFolder();

    pms_xml.clear();//pms_xml的名称
    pms_filename.clear();
//    guowangflag = false;
    if(FID_PID_MODE)
    {
        fidpid = true;
    }
    //IsWifiSearch = false;

     IP = "";
     Account = "";
     Password = "";

     mainmode = 0;

     Taskmode = false;

     isInSrvCancelUpload = false;
     mymode = enum_AUP_SERVER;

     ui->title_warning->hide();
     ui->flag_warning->hide();
     ui->text_warning->hide();

     AutoUpdateGetStatus = new QTimer();
     AutoUpdateGetStatus->setInterval(500);

    setGeometry((640-width())/2+160,(480-height())/2,width(),height());  //384-> 640  96->160  272->480
    setFixedSize(this->width(), this->height());
    connect(&timer1s,SIGNAL(timeout()),this,SLOT(slot_timer_1s()));
    connect(&timer3s,SIGNAL(timeout()),this,SLOT(slot_timer_3s()));
    connect(&hti,SIGNAL(sync_text()),this,SLOT(slot_sync_text()));
    connect(&hti,SIGNAL(signal_frminput_set_lcd_offed_state()),this,SLOT(slot_cameracap_set_lcd_offed_state()));
    connect(AutoUpdateGetStatus,SIGNAL(timeout()),this,SLOT(slot_Time_out()));

    QString para;
    para = hpxmlreader.readXml("sys.xml","LANGUAGEPARA","id");
    if(para !=NULL)
    {
        if(para.toInt() == 0)
        {
            HasNorelease = "没有文本注释";
            Hasrelease = "文本注释:";
            StartVoice = "开始录音";
            EndVoice = "录音结束";
            SaveOK = "保存成功";
            IsInCancelUpload = "正在取消上传";
            CancelUploadOK = "成功取消上传";
            UploadOK = "上传成功";
            UploadWrong = "上传失败";
            IsInAutoUpload = "正在上传";
            RecordError = "录制失败";
            WaitShow = "等待加载，请稍候";
            analysisError = "播放失败";
            fReconnect = "请重新连接服务器";
        }
        else if(para.toInt() == 1)
        {
            HasNorelease = "沒有文本注釋";
            Hasrelease = "文本注釋:";
            StartVoice = "開始錄音";
            EndVoice = "錄音結束";
            SaveOK = "保存成功";
            IsInCancelUpload = "正在取消上傳";
            CancelUploadOK = "成功取消上傳";
            UploadOK = "上傳成功";
            UploadWrong = "上傳失敗";
            IsInAutoUpload = "正在上傳";
            RecordError = "錄製失敗";
            WaitShow = "等待加載，請稍候";
            analysisError = "播放失敗";
            fReconnect = "請重新連接服務器";
        }
        else if(para.toInt() == 2)//english
        {
            HasNorelease = "No text note";
            Hasrelease = "Text note:";
            StartVoice = "Start recording";
            EndVoice = "End recording";
            SaveOK = "Saved successfully";
            IsInCancelUpload = "Canceling upload";
            CancelUploadOK = "Upload cancelled successfully";
            UploadOK = "Upload successful";
            UploadWrong = "Upload failed";
            IsInAutoUpload = "Uploading";
            RecordError = "Recording failed";
            WaitShow = "wait please";
            analysisError = "failed";
            fReconnect = "Reconnect server";
        }
        else if(para.toInt() == 3)//俄语
        {
            HasNorelease = "Нет заметки";
            Hasrelease = "текст:";
            StartVoice = "запись";
            EndVoice = "оконч запись";
            SaveOK = "сохранено";
            IsInCancelUpload = "отменить загрузку";
            CancelUploadOK = "успешно отменить загрузку";
            UploadOK = "Загрузка завершена";
            UploadWrong = "Ошибка загрузки";
            IsInAutoUpload = "идёт загрузка";
            RecordError = "Ошибка записи";
            WaitShow = "wait please";
            analysisError = "записи";
            fReconnect = "пересоединённый сервер";
        }
        else if(para.toInt() == 4)//匈牙利语
        {
            HasNorelease = "nincs szöveg";
            Hasrelease = "Szöveg:";
            StartVoice = "Felvétel indítás";
            EndVoice = "Felvétel leállítás";
            SaveOK = "Sikeres mentés";
            IsInCancelUpload = "Feltöltés törlése";
            CancelUploadOK = "Feltöltés sikeresen törölve";
            UploadOK = "Feltöltés sikeres";
            UploadWrong = "Feltöltés sikertelen";
            IsInAutoUpload = "Feltöltés";
            RecordError = "Felvétel sikertelen";
            WaitShow = "wait please";
            analysisError = "sikertelen";
            fReconnect = "kiszolgáló újracsatlakozása";
        }
        else if(para.toInt() == 5)//西班牙语
        {
            HasNorelease = "No hay nota de texto";
            Hasrelease = "Nota Texto:";
            StartVoice = "Comenzar a grabar";
            EndVoice = "Terminar de grabar";
            SaveOK = "Guardado exitosamente";
            IsInCancelUpload = "Cancelando carga";
            CancelUploadOK = "Carga cancelada con éxito";
            UploadOK = "Subida exitosa";
            UploadWrong = "Fallo de carga";
            IsInAutoUpload = "Subiendo";
            RecordError = "Falló la grabación";
            WaitShow = "wait please";
            analysisError = "grabación";
            fReconnect = "Reconectar el servidor";
        }
    }
}

Hp_Camera_Cap::~Hp_Camera_Cap()
{
    delete ui;
}
void Hp_Camera_Cap::hp_setDefine_S3x0(bool isSelect)
{
    if(isSelect)
    {
        isS3X0 = isSelect;
        QFont font10;
        font10.setPointSize(10);

        this->setGeometry(96,0,384,272);
        ui->frame->setGeometry(112,113,160,121);
        ui->frame_2->setGeometry(0,60,154,40);
        ui->toolButton_cancel->setGeometry(117,2,36,36);
        ui->toolButton_save->setGeometry(79,2,36,36);
        ui->toolButton_text->setGeometry(3,2,36,36);
        ui->toolButton_voice->setGeometry(41,2,36,36);
        ui->label->setGeometry(2,2,156,16);
        ui->label_jpgname->setGeometry(-2,20,170,16);
        ui->label_jpgname_2->setGeometry(0,40,170,16);
        ui->progressBar->setGeometry(1,102,154,14);
        ui->label_time->setGeometry(78,212,40,20);
        ui->text_warning->setGeometry(ui->text_warning->x() / 1.7,ui->text_warning->y() / 1.7,ui->text_warning->width() / 1.7,ui->text_warning->height() / 1.7);
        ui->title_warning->setGeometry(ui->title_warning->x() / 1.7,ui->title_warning->y() / 1.7,ui->title_warning->width() / 1.7,ui->title_warning->height() / 1.7);
        ui->flag_warning->setGeometry(ui->flag_warning->x() / 1.7,ui->flag_warning->y() / 1.7,ui->flag_warning->width() / 1.7,ui->flag_warning->height() / 1.7);

        ui->label->setFont(font10);
        ui->label_jpgname->setFont(font10);
        ui->label_jpgname_2->setFont(font10);
        ui->label_time->setFont(font10);
        ui->text_warning->setFont(font10);
        ui->title_warning->setFont(font10);
        ui->flag_warning->setFont(font10);
    }
    hti.hp_setDefine_S3x0(isSelect);
}

void Hp_Camera_Cap::slot_setTaskTest(QString flag, QString title, QString text)
{
    if(m_isPms)
    {
        return;
    }
    qDebug() << "flag == > " << flag;
    qDebug() << "title == > " << title;
    qDebug() << "text == > " << text;
    if(flag == "Normal")
    {
        flag = "正常";
    }
    if(flag == "Care")
    {
        flag = "关注";
    }
    if(flag == "General")
    {
        flag = "一般缺陷";
    }
    if(flag == "Serious")
    {
        flag = "严重缺陷";
    }
    if(flag == "Crisis")
    {
        flag = "紧急缺陷";
    }
    if(flag == "Unknown")
    {
        flag = "未知";
    }
    if(flag == "正常")
    {
        ui->flag_warning->setStyleSheet("background-color: transparent;\
                color: \"#00ff00\";");
    }else if(flag == "关注")
    {
        ui->flag_warning->setStyleSheet("background-color: transparent;\
                color: \"#ff0096\";");
    }else if(flag == "一般缺陷")
    {
        ui->flag_warning->setStyleSheet("background-color: transparent;\
                color: \"#ffff00\";");
    }else if(flag == "严重缺陷")
    {
        ui->flag_warning->setStyleSheet("background-color: transparent;\
                color: \"#ec7a4d\";");
    }else if(flag == "紧急缺陷")
    {
        ui->flag_warning->setStyleSheet("background-color: transparent;\
                color: \"#ff0000\";");
    }else if(flag == "未知")
    {
        ui->flag_warning->setStyleSheet("background-color: transparent;\
                color: \"#ffffff\";");
    }
    if(!flag.isEmpty() && !title.isEmpty()) {
        ui->flag_warning->setText(flag);
        ui->title_warning->setText(title);
        ui->text_warning->setText(text);
        ui->flag_warning->show();
        ui->title_warning->show();
        ui->text_warning->show();
    } else {
        ui->flag_warning->setText("未知");
        ui->flag_warning->show();
    }
}
void Hp_Camera_Cap::slot_HideTaskText()
{
    ui->flag_warning->close();
    ui->title_warning->close();
    ui->text_warning->close();
}
void Hp_Camera_Cap::slot_Time_out()
{
    signal_core_get_upload_status();//获取自动上传状态
}
